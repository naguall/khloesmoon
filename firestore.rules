// ============================================================
// FIRESTORE SECURITY RULES
// Proyecto: astroconnect-463b3
// Cubre: AstroConnect / Moon Tracker  +  Khloe's Moon
// ============================================================
// IMPORTANTE: Si ya tienes reglas personalizadas para
// AstroConnect/Moon Tracker, sólo copia/pega el bloque marcado
// "KHLOE'S MOON" al final de tu bloque `match /databases/.../documents`.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helper ----------
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ============================================================
    // ASTROCONNECT / MOON TRACKER
    // (Colecciones originales del proyecto astroconnect)
    // ============================================================

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isSelf(uid);
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;

      match /posts/{postId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update: if signedIn();
        allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;

        match /comments/{commentId} {
          allow read: if signedIn();
          allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
          allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
        }
      }
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if signedIn() &&
          request.auth.uid == request.resource.data.senderUid &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /feed/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
        allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
      }
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, update: if isSelf(uid);
      allow create: if signedIn();
    }

    match /cosmicGroups/{groupId} {
      allow read: if signedIn();
      allow create, update: if signedIn();

      match /chat/{msgId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.senderUid == request.auth.uid;
      }
    }

    // ============================================================
    // KHLOE'S MOON  (aislado en colecciones con prefijo khloesmoon_)
    // Esto garantiza que NUNCA choque con los datos de AstroConnect.
    // ============================================================

    // Perfil público mínimo de cada usuaria de Khloe's Moon:
    // { shareCode, name, email?, updatedAt }
    // Cualquiera autenticada puede leer (para buscar por shareCode),
    // pero sólo la dueña puede escribir su propio documento.
    match /khloesmoon_users/{uid} {
      allow read: if signedIn();
      allow write: if isSelf(uid);
    }

    // Chats 1:1 entre amigas.
    // chatId es determinístico: uidA_uidB (ordenado lex.)
    // Sólo los dos participantes pueden leer/escribir.
    match /khloesmoon_chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        // Sólo los participantes del chat padre pueden leer
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/khloesmoon_chats/$(chatId)).data.participants;
        // Sólo la propia usuaria puede escribir mensajes como sí misma,
        // y debe ser participante del chat
        allow create: if signedIn() &&
          request.auth.uid == request.resource.data.senderUid &&
          request.auth.uid in get(/databases/$(database)/documents/khloesmoon_chats/$(chatId)).data.participants;
        allow update: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/khloesmoon_chats/$(chatId)).data.participants;
        allow delete: if false;
      }
    }
  }
}
